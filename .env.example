# Google Gemini — get free key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Database
POSTGRES_DB=advisor
POSTGRES_USER=advisor
POSTGRES_PASSWORD=advisor_local
DATABASE_URL=postgresql://advisor:advisor_local@localhost:5432/advisor

# App
PORT=3000
NODE_ENV=development

# RAG Configuration
VECTOR_SIMILARITY_THRESHOLD=0.7
RAG_TOP_K=5

# Conversation Limits
MAX_MESSAGES_PER_SESSION=20
MAX_CLARIFICATION_ROUNDS=5
REQUIREMENTS_COMPLETENESS_THRESHOLD=70
SESSION_TTL_HOURS=2
