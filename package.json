{
  "name": "ai-cloud-architecture-advisor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "cd apps/api && npm run start:dev",
    "build": "cd apps/api && npm run build",
    "lint": "cd apps/api && npm run lint",
    "type-check": "cd apps/api && npx tsc --noEmit",
    "test": "cd apps/api && npm run test",
    "test:unit": "cd apps/api && npm run test:unit",
    "test:integration": "cd apps/api && npm run test:integration",
    "ingest": "cd apps/api && node --env-file=../../.env node_modules/ts-node/dist/bin.js -r tsconfig-paths/register src/scripts/ingest-knowledge-base.ts"
  }
}
